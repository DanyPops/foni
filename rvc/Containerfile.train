FROM docker.io/runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server libsndfile1 && \
    rm -rf /var/lib/apt/lists/* && \
    mkdir -p /run/sshd

RUN pip install --no-cache-dir faiss-cpu praat-parselmouth pyworld scipy

CMD ["bash", "-c", "service ssh start && sleep infinity"]
